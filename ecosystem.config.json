{
  "apps": [
    {
      "name": "domo-backend",
      "script": "/home/ubuntu/domo-toolkit/backend/.venv/bin/uvicorn",
      "args": "app.main:app --host 127.0.0.1 --port 8000",
      "cwd": "/home/ubuntu/domo-toolkit/backend",
      "interpreter": "none",
      "env": {
        "PYTHONUTF8": "1",
        "PATH": "/home/ubuntu/domo-toolkit/backend/.venv/bin:/usr/local/bin:/usr/bin:/bin"
      },
      "max_restarts": 10,
      "restart_delay": 3000,
      "watch": false,
      "log_date_format": "YYYY-MM-DD HH:mm:ss"
    }
  ]
}